# Database
DATABASE_URL=mysql://lilly:CHANGE_ME@db:3306/lilly # ggignore
MARIADB_ROOT_PASSWORD=CHANGE_ME # ggignore
MARIADB_DATABASE=lilly
MARIADB_USER=lilly
MARIADB_PASSWORD=CHANGE_ME # ggignore

# Auth
JWT_SECRET=CHANGE_ME # ggignore
JWT_ACCESS_TOKEN_EXPIRY=900
JWT_REFRESH_TOKEN_EXPIRY=2592000

# Backend
RUST_LOG=info
BACKEND_PORT=8080
# Set to true only for local development/testing — never in production
ENABLE_DEMO_SEED=false

# SMTP (optional — if SMTP_HOST is not set, verification emails are logged to console)
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=noreply@lilly.app

# App
APP_BASE_URL=http://localhost
COOKIE_SECURE=false
ADMIN_EMAIL=
MEDIA_PATH=/media
MEDIA_URL_PREFIX=/media
